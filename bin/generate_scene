#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "remarkable/io/rm_page"
require "remarkable/io/rmdoc_writer"
require "remarkable/scenes/flag_scenes"

SCENES = {
  "shape-sampler" => Remarkable::Scenes::FlagScenes.method(:draw_shape_sampler),
  "us-flag" => Remarkable::Scenes::FlagScenes.method(:draw_us_flag),
  "greenland-flag" => Remarkable::Scenes::FlagScenes.method(:draw_greenland_flag)
}.freeze

def print_usage
  puts "Usage: ruby bin/generate_scene <scene-name> [output-file]"
  puts "Available scenes:"
  SCENES.keys.each { |name| puts "  #{name}" }
end

if ARGV.empty? || %w[--help -h].include?(ARGV[0])
  print_usage
  exit 0
end

scene_name = ARGV[0]
renderer = SCENES[scene_name]
unless renderer
  warn "Unknown scene: #{scene_name}"
  print_usage
  exit 2
end

output_name = ARGV[1] || "out/#{scene_name}.rmdoc"
page = Remarkable::IO::RmPage.new
renderer.call(page)
Remarkable::IO::RmdocWriter.write(output_name, page.to_rm_bytes)
