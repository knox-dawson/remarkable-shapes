#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "version"
require "slop"
require "io/rm_page"
require "io/rmdoc_writer"
require "shapes/image_generator"

def build_options(argv)
  Slop.parse(argv) do |o|
    o.banner = <<~BANNER
      Usage: ruby bin/generate_image --input PNG_PATH [options]

      Example:
        ruby bin/generate_image --input examples/cat.png --output out/cat-image.rmdoc
    BANNER

    o.string "-i", "--input", "PNG file to render"
    o.string "-o", "--output", "Output .rmdoc path"
    o.integer "-d", "--downsample", "Average each NxN block before rendering"
    o.bool "-v", "--version", "Print version"
    o.bool "-h", "--help", "Show help"
  end
end

options = build_options(ARGV)

if options[:help]
  puts options
  exit 0
end

if options[:version]
  puts Remarkable::VERSION
  exit 0
end

png_path = options[:input]
if png_path.nil? || png_path.strip.empty?
  warn "Missing required option: --input"
  warn options
  exit 2
end

unless File.extname(png_path).downcase == ".png"
  warn "generate_image only supports PNG input: #{png_path}"
  exit 2
end

unless File.file?(png_path)
  warn "PNG file not found: #{png_path}"
  exit 2
end

default_name = File.basename(png_path, ".png")
output_path = options[:output] || "out/#{default_name}.rmdoc"

page = Remarkable::RmPage.new
Remarkable::ImageGenerator.draw_png(page, png_path, downsample: options[:downsample] || 1)
Remarkable::RmdocWriter.write(output_path, page.to_rm_bytes)
