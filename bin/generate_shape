#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "version"
require "io/rm_page"
require "io/rmdoc_writer"
require "shapes/shapes"
require "shapes/line_font"

EXAMPLES_DIR = File.expand_path("../examples", __dir__)

def print_usage
  puts "Usage: ruby bin/generate_shape <shape-file-or-name> [output-file]"
  puts
  puts "Examples:"
  puts "  ruby bin/generate_shape examples/us-flag.rb out/us-flag.rmdoc"
  puts "  ruby bin/generate_shape us-flag"
  puts "  REMARKABLE_SHAPES_PATH=/path/to/shape-repo ruby bin/generate_shape post-it/example"
  puts
  puts "A shape file must evaluate to a callable object, for example:"
  puts "  ->(page) { Remarkable::Shapes.rm2_box(page) }"
end

def shape_search_roots
  roots = [EXAMPLES_DIR]
  env_roots = ENV.fetch("REMARKABLE_SHAPES_PATH", "")
                 .split(File::PATH_SEPARATOR)
                 .reject(&:empty?)
  roots.concat(env_roots)
  roots.uniq
end

def resolve_shape_path(shape_name)
  candidates = [shape_name, "#{shape_name}.rb"]
  shape_search_roots.each do |root|
    candidates << File.join(root, shape_name)
    candidates << File.join(root, "#{shape_name}.rb")
  end

  candidates
    .map { |path| File.expand_path(path, Dir.pwd) }
    .find { |path| File.file?(path) }
end

def load_local_renderer(path)
  renderer = eval(File.read(path), TOPLEVEL_BINDING, path)
  return renderer if renderer.respond_to?(:call)

  warn "Shape file must evaluate to a callable object: #{path}"
  exit 2
end

if ARGV.empty? || %w[--help -h].include?(ARGV[0])
  print_usage
  exit 0
end

if %w[--version -v].include?(ARGV[0])
  puts Remarkable::VERSION
  exit 0
end

shape_name = ARGV[0]
shape_path = resolve_shape_path(shape_name)
unless shape_path
  warn "Unknown shape or file: #{shape_name}"
  print_usage
  exit 2
end

renderer = load_local_renderer(shape_path)
default_name = File.basename(shape_path, ".rb")
output_name = ARGV[1] || "out/#{default_name}.rmdoc"
page = Remarkable::RmPage.new
renderer.call(page)
Remarkable::RmdocWriter.write(output_name, page.to_rm_bytes)
