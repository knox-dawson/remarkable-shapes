#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "version"
require "slop"
require "io/rm_page"
require "shapes/yaml_shape_page_generator"

def build_options(argv)
  Slop.parse(argv) do |o|
    o.banner = <<~BANNER
      Usage: ruby bin/generate_yaml_pages --image-dir IMAGE_DIR --layout ROWSxCOLS [options]

      Example:
        ruby bin/generate_yaml_pages --image-dir emoji --layout 3x5 --output-dir examples/emoji-pages --prefix emoji --outer-padding 40 --cell-gap 30 --pixel-gap -0.10

      Notes:
        outer-padding adds margin inside the rm2 box
        cell-gap sets spacing between image cells
        pixel-gap is written to each YAML image object as gap
        use a negative pixel-gap for slight pixel overlap
    BANNER

    o.string "-i", "--image-dir", "Directory containing PNG files"
    o.string "-l", "--layout", "Grid layout such as 3x5"
    o.string "-o", "--output-dir", "Directory to write generated YAML pages"
    o.string "-p", "--prefix", "Filename prefix for generated YAML pages"
    o.float "--outer-padding", "Padding inside the rm2 box"
    o.float "--cell-gap", "Spacing between image cells"
    o.float "--pixel-gap", "Gap written to each YAML image object"
    o.bool "-v", "--version", "Print version"
    o.bool "-h", "--help", "Show help"
  end
end

options = build_options(ARGV)

if options[:help]
  puts options
  exit 0
end

if options[:version]
  puts Remarkable::VERSION
  exit 0
end

image_dir = options[:image_dir]
layout = options[:layout]
if image_dir.nil? || image_dir.strip.empty?
  warn "Missing required option: --image-dir"
  warn options
  exit 2
end
if layout.nil? || layout.strip.empty?
  warn "Missing required option: --layout"
  warn options
  exit 2
end

default_dirname = "#{File.basename(File.expand_path(image_dir))}-pages"
output_dir = options[:output_dir] || File.join("examples", default_dirname)
prefix = options[:prefix]
outer_padding = options[:outer_padding] || Remarkable::YamlShapePageGenerator::DEFAULT_OUTER_PADDING
cell_gap = options[:cell_gap] || Remarkable::YamlShapePageGenerator::DEFAULT_CELL_GAP
pixel_gap = options[:pixel_gap] || Remarkable::YamlShapePageGenerator::DEFAULT_PIXEL_GAP

generated = Remarkable::YamlShapePageGenerator.generate(
  image_dir:,
  layout:,
  output_dir:,
  prefix:,
  outer_padding:,
  cell_gap:,
  pixel_gap:
)

generated.each { |path| puts path }
