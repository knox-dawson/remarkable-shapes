#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "version"
require "slop"
require "pathname"
require "io/rm_page"
require "io/rmdoc_writer"
require "shapes/shapes"
require "shapes/line_font"

EXAMPLES_DIR = File.expand_path("../examples", __dir__)

def build_options(argv)
  Slop.parse(argv) do |o|
    o.banner = <<~BANNER
      Usage: bin/generate_shape --input SHAPE_FILE_OR_NAME [options]

      Examples:
        bin/generate_shape --input examples/us-flag.rb --output out/us-flag.rmdoc
        bin/generate_shape --input us-flag
        bin/generate_shape --input post-it/example --shapes-path /path/to/shape-repo

      A shape file must evaluate to a callable object, for example:
        ->(page) { Remarkable::Shapes.rm2_box(page) }
    BANNER

    o.string "-i", "--input", "Shape file path or shape name"
    o.string "-o", "--output", "Output .rmdoc path"
    o.array "--shapes-path", "Extra search roots, repeated or comma-separated"
    o.bool "-v", "--version", "Print version"
    o.bool "-h", "--help", "Show help"
  end
end

def shape_search_roots(extra_roots = [])
  roots = [EXAMPLES_DIR]
  env_roots = ENV.fetch("REMARKABLE_SHAPES_PATH", "")
                 .split(File::PATH_SEPARATOR)
                 .reject(&:empty?)
  roots.concat(env_roots)
  roots.concat(extra_roots)
  roots.uniq
end

def resolve_shape_path(shape_name, extra_roots = [])
  candidates = [
    { path: shape_name, root: nil },
    { path: "#{shape_name}.rb", root: nil }
  ]
  shape_search_roots(extra_roots).each do |root|
    candidates << { path: File.join(root, shape_name), root: root }
    candidates << { path: File.join(root, "#{shape_name}.rb"), root: root }
  end

  candidates
    .map do |candidate|
      {
        path: File.expand_path(candidate.fetch(:path), Dir.pwd),
        root: candidate.fetch(:root)&.then { |root| File.expand_path(root, Dir.pwd) }
      }
    end
    .find { |candidate| File.file?(candidate.fetch(:path)) }
end

def resolve_output_path(output_name, resolved_root)
  return output_name if output_name.nil? || output_name.strip.empty?
  return output_name if Pathname.new(output_name).absolute?
  return output_name if resolved_root.nil?
  return output_name if resolved_root == File.expand_path(EXAMPLES_DIR)

  File.expand_path(output_name, resolved_root)
end

def load_local_renderer(path)
  renderer = eval(File.read(path), TOPLEVEL_BINDING, path)
  return renderer if renderer.respond_to?(:call)

  warn "Shape file must evaluate to a callable object: #{path}"
  exit 2
end

options = build_options(ARGV)

if options[:help]
  puts options
  exit 0
end

if options[:version]
  puts Remarkable::VERSION
  exit 0
end

shape_name = options[:input]
if shape_name.nil? || shape_name.strip.empty?
  warn "Missing required option: --input"
  warn options
  exit 2
end

shape_resolution = resolve_shape_path(shape_name, options[:shapes_path] || [])
unless shape_resolution
  warn "Unknown shape or file: #{shape_name}"
  warn options
  exit 2
end

shape_path = shape_resolution.fetch(:path)
resolved_root = shape_resolution.fetch(:root)
renderer = load_local_renderer(shape_path)
default_name = File.basename(shape_path, ".rb")
output_name = resolve_output_path(options[:output] || "out/#{default_name}.rmdoc", resolved_root)
page = Remarkable::RmPage.new
renderer.call(page)
Remarkable::RmdocWriter.write(output_name, page.to_rm_bytes)
