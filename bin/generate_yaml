#!/usr/bin/env ruby
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "version"
require "slop"
require "io/rm_page"
require "io/rmdoc_writer"
require "shapes/yaml_shape_renderer"

EXAMPLES_DIR = File.expand_path("../examples", __dir__)

def build_options(argv)
  Slop.parse(argv) do |o|
    o.banner = <<~BANNER
      Usage: bin/generate_yaml --input YAML_FILE_OR_NAME [options]

      Examples:
        bin/generate_yaml --input examples/basic-shapes.yml --output out/basic-shapes.rmdoc
        bin/generate_yaml --input basic-shapes --shapes-path /path/to/shape-repo
    BANNER

    o.string "-i", "--input", "YAML file path or example name"
    o.string "-o", "--output", "Output .rmdoc path"
    o.array "--shapes-path", "Extra search roots, repeated or comma-separated"
    o.bool "-v", "--version", "Print version"
    o.bool "-h", "--help", "Show help"
  end
end

def shape_search_roots(extra_roots = [])
  roots = [EXAMPLES_DIR]
  env_roots = ENV.fetch("REMARKABLE_SHAPES_PATH", "")
                 .split(File::PATH_SEPARATOR)
                 .reject(&:empty?)
  roots.concat(env_roots)
  roots.concat(extra_roots)
  roots.uniq
end

def resolve_yaml_path(input_name, extra_roots = [])
  candidates = [input_name, "#{input_name}.yml", "#{input_name}.yaml"]
  shape_search_roots(extra_roots).each do |root|
    candidates << File.join(root, input_name)
    candidates << File.join(root, "#{input_name}.yml")
    candidates << File.join(root, "#{input_name}.yaml")
  end

  candidates
    .map { |path| File.expand_path(path, Dir.pwd) }
    .find { |path| File.file?(path) }
end

options = build_options(ARGV)

if options[:help]
  puts options
  exit 0
end

if options[:version]
  puts Remarkable::VERSION
  exit 0
end

input_name = options[:input]
if input_name.nil? || input_name.strip.empty?
  warn "Missing required option: --input"
  warn options
  exit 2
end

yaml_path = resolve_yaml_path(input_name, options[:shapes_path] || [])
unless yaml_path
  warn "YAML file not found: #{input_name}"
  exit 2
end

default_name = File.basename(yaml_path, File.extname(yaml_path))
output_path = options[:output] || "out/#{default_name}.rmdoc"

config = Remarkable::YamlShapeRenderer.load_file_config(yaml_path)
layout = Remarkable::YamlShapeRenderer.resolve_canvas_layout(config.fetch("canvas", {}))
page = Remarkable::RmPage.new(page_width: layout[:physical_width], page_height: layout[:physical_height])
Remarkable::YamlShapeRenderer.render(page, config, base_dir: File.dirname(File.expand_path(yaml_path)))
Remarkable::RmdocWriter.write(
  output_path,
  page.to_rm_bytes,
  page_width: page.page_width,
  page_height: page.page_height
)
